# bash version target (project requires Bash >= 4.2 for declare -A and [[ -v ]])
shell=bash

# Allow external source directives
external-sources=true

# Source path for shellcheck source resolution
source-path=SCRIPTDIR

# Warnings to exclude
# Note: verified non-triggering on shellcheck 0.10.0; kept for older versions
# SC2034: unused variables in sourced scripts (config.sh defines vars for other scripts)
# SC2119: llama_acquire_lock uses default LOCK_FILE, doesn't need "$@"
# SC2312: pipefail grep patterns are intentional
# SC2317: return N 2>/dev/null || exit N is intentional idiomatic bash
disable=SC2034,SC2119,SC2312,SC2317

